{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "experiment-critic final decision",
  "type": "object",
  "additionalProperties": true,
  "required": ["verdict", "rationale", "confidence"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["accept", "reject", "no_op"]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "target_id": {
      "type": "string"
    },
    "baseline_leg": {
      "type": "string"
    },
    "candidate_leg": {
      "type": "string"
    },
    "promotability_notes": {
      "type": "string"
    },
    "cluster_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
